# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# Force HTTPS (optional - uncomment when deployed)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www (optional - uncomment when deployed)
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Redirect index.html to root
RewriteCond %{THE_REQUEST} ^GET\ /index\.html\ HTTP
RewriteRule ^index\.html$ / [R=301,L]

# Redirect old URLs with .html extension to clean URLs
RewriteCond %{THE_REQUEST} ^GET\ /pages/(blog|kontakt|o-nas|produkty-sluzby|referencie|ochrana-osobnych-udajov)\.html\ HTTP
RewriteRule ^pages/(.*)\.html$ /$1 [R=301,L]

# Redirect direct page access to clean URLs
RewriteCond %{THE_REQUEST} ^GET\ /pages/([^.]+)\.html\ HTTP
RewriteRule ^pages/([^.]+)\.html$ /$1 [R=301,L]

# Rewrite root to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^$ index.html [L]

# Product category redirects (new URL structure)
# Main categories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produkty/nabytok$ produkty/nabytok.html [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produkty/schody$ produkty/schody.html [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produkty/zarubne$ produkty/zarubne.html [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produkty/obklady$ produkty/obklady.html [L]

# Dvere series pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produkty/dvere/seria-([aefghisv])$ produkty/dvere/seria-$1.html [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produkty/dvere/dvere-(bezfalcove|posuvne|falcove)$ produkty/dvere/dvere-$1.html [L]

# Celoskla series pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produkty/celoskla/celoskla-(css|csps|csp|sk|csz|csal)$ produkty/celoskla/celoskla-$1.html [L]

# Redirect dvere main category to first series (since dvere has no main page)
RewriteRule ^produkty/dvere/?$ /produkty/dvere/seria-a [R=301,L]

# Redirect celoskla main category to first series (since celoskla has no main page)
RewriteRule ^produkty/celoskla/?$ /produkty/celoskla/celoskla-css [R=301,L]

# Redirect old produkty-sluzby page to appropriate new structure
RewriteRule ^produkty-sluzby/?$ /produkty/nabytok [R=301,L]

# Rewrite clean URLs to actual files in pages directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(blog|kontakt|o-nas|referencie|ochrana-osobnych-udajov)$ pages/$1.html [L]

# For files in root, add .html if it exists
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)$ $1.html [L]

# Security: Prevent access to sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent directory browsing
Options -Indexes

# Error Pages (optional)
ErrorDocument 404 /404.html

# Set default charset
AddDefaultCharset UTF-8

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Cache-Control Headers
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|css|js)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
